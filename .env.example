# ------------------------------------------------------------------
# Broward Arrest Records — environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or real secrets to the repository.
# ------------------------------------------------------------------

# Supabase project (Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server/scraper only. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Simple password gate for /admin (MVP-level protection)
ADMIN_PASSWORD=

# Official Broward Sheriff's Office booking blotter source
BROWARD_SOURCE_URL=https://bookingblotter.sheriff.org/app/

# Identify the scraper honestly. Include a real contact address.
SCRAPER_USER_AGENT="Broward Arrest Resource MVP - contact@example.com"

# Optional ---------------------------------------------------------

# Public site URL, used for metadata, sitemap and canonical links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Display mugshot images on the site. Default is "false": the record
# stores the official mugshot URL but the site does not hotlink the
# image unless you have confirmed the source policy allows it.
NEXT_PUBLIC_DISPLAY_MUGSHOTS=false

# Secret used to protect the /api/cron/scrape endpoint (Vercel Cron
# sends it automatically as "Authorization: Bearer <CRON_SECRET>")
CRON_SECRET=

# Milliseconds to wait between scraper HTTP requests (politeness delay)
SCRAPER_DELAY_MS=2500

# Hard cap on records processed per scraper run
SCRAPER_MAX_RECORDS=500
